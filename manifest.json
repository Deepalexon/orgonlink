{
  "manifest_version": 3,
  "name": "OrgonLink",
  "version": "0.19.0",
  "version_name": "0.19.0",
  "description": "OrgonLink — несохранный кошелёк для блокчейна Orgon: переводы, oRC-20, стейкинг, делегирование и подключение к dApp.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "alarms",
    "tabs",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "dist/background/service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "dist/provider/orgonWeb.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "dist/content/bridge.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dist/provider/orgonWeb.js"
      ],
      "matches": [
        "https://*/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "homepage_url": "https://orgon.space"
}